Try logging in again. If it still fails, run this to confirm the database connection works locally:
bashnode -e "
const { PrismaClient } = require('@prisma/client');
const prisma = new PrismaClient();
prisma.user.count().then(n => {
  console.log('DB connected. Users:', n);
  prisma.\$disconnect();
}).catch(e => {
  console.error('DB connection FAILED:', e.message);
  prisma.\$disconnect();
});
"
Paste what it prints — that will confirm whether the database connection is the issue or something else.
