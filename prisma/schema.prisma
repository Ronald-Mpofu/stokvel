// ============================================================
// STOKVEL MANAGEMENT PLATFORM — Prisma Schema
// Database: PostgreSQL (Supabase)
// Version: 1.0.0
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SYSTEM_ADMIN
  NATIONAL_ADMIN
  GROUP_ADMIN
  TREASURER
  INVESTMENT_MANAGER
  MEMBER
  AUDITOR
}

enum KycStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum MemberTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum MemberStatus {
  ACTIVE
  SUSPENDED
  DEFAULTED
  EXITED
  BLACKLISTED
}

enum GroupStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  DISSOLVED
}

enum CycleStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PayoutStrategy {
  RANDOM
  SENIORITY
  GROUP_VOTE
}

enum ContributionStatus {
  PENDING
  PAID
  PRE_PAID
  LATE
  FAILED
  DEFAULTED
  WAIVED
}

enum PayoutStatus {
  SCHEDULED
  PENDING_GATES
  PROCESSING
  COMPLETED
  HELD
  CANCELLED
}

enum AssetType {
  VEHICLE
  AGRICULTURAL_MACHINERY
  INDUSTRIAL_MACHINERY
  COMPUTER_EQUIPMENT
  HOME
  OTHER
}

enum AssetStatus {
  FUNDING
  ACQUIRED
  ACTIVE
  DISPOSED
  WRITTEN_OFF
}

enum AssetCampaignType {
  SHARED_OWNERSHIP   // Group buys one asset, all co-own proportionally
  ROUND_ROBIN        // Each member gets their own asset in turn
}

enum AssetQueueStatus {
  WAITING      // Not their turn yet
  FUNDING      // Currently accumulating funds for this member
  SOURCING     // Enough funds — supplier being engaged
  ORDERED      // Purchase order placed
  DELIVERED    // Asset delivered and handed over
  SKIPPED      // Member skipped their turn
}

enum BackerStatus {
  PENDING_KYC
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  WITHDRAWN
  REJECTED
}

enum BackerKycStatus {
  NOT_SUBMITTED
  SUBMITTED
  VERIFIED
  REJECTED
}

enum LoanStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_APPROVAL
  APPROVED
  DISBURSED
  ACTIVE
  SETTLED
  DEFAULTED
  REJECTED
  CANCELLED
}

enum LoanType {
  STANDARD
  EMERGENCY
  BUSINESS
}

enum TransactionType {
  CONTRIBUTION
  PAYOUT
  PRE_ESCROW
  LOAN_DISBURSEMENT
  LOAN_REPAYMENT
  ASSET_CONTRIBUTION
  RENTAL_INCOME
  INVESTMENT_CONTRIBUTION
  INVESTMENT_RETURN
  INSURANCE_POOL
  FEE
  REFUND
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REVERSED
  CANCELLED
}

enum PaymentMethod {
  ECOCASH
  MPESA
  MTN_MOMO
  BANK_TRANSFER
  CARD
  USSD
  INTERNAL_TRANSFER
}

enum CurrencyCode {
  USD
  ZAR
  ZWG
  KES
  TZS
  UGX
  ZMW
  BWP
  MWK
  EUR
  GBP
}

enum InvestmentType {
  UNIT_TRUST
  EQUITY
  BOND
  BUSINESS_VENTURE
  MONEY_MARKET
  PROPERTY_FUND
}

enum NotificationChannel {
  SMS
  EMAIL
  WHATSAPP
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

enum DisputeType {
  NON_PAYMENT
  FRAUD
  UNAUTHORIZED_EXIT
  INCORRECT_CALCULATION
  GOVERNANCE
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED
  CLOSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  DISBURSE
  TRANSFER
  EXPORT
  VIEW_SENSITIVE
}

// ============================================================
// CORE USER & IDENTITY
// ============================================================

model User {
  id                String       @id @default(uuid())
  email             String       @unique
  phone             String       @unique
  passwordHash      String
  fullName          String
  dateOfBirth       DateTime?
  nationalIdHash    String?      // Hashed national ID — never store raw
  nationalIdVerified Boolean     @default(false)
  kycStatus         KycStatus    @default(PENDING)
  kycDocumentUrl    String?      // Encrypted document URL
  kycReviewedAt     DateTime?
  kycReviewedBy     String?
  role              UserRole     @default(MEMBER)
  tier              MemberTier   @default(BRONZE)
  reputationScore   Decimal      @default(0) @db.Decimal(8, 2)
  status            MemberStatus @default(ACTIVE)
  isBlacklisted     Boolean      @default(false)
  blacklistReason   String?
  blacklistedAt     DateTime?
  referralCode      String       @unique @default(uuid())
  referredById      String?
  preferredCurrency CurrencyCode @default(USD)
  profilePhotoUrl   String?
  address           String?
  city              String?
  country           String?
  mfaEnabled        Boolean      @default(false)
  mfaSecret         String?      // Encrypted TOTP secret
  lastLoginAt       DateTime?
  lastLoginIp       String?
  emailVerifiedAt   DateTime?
  phoneVerifiedAt   DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  // Relations
  referredBy            User?                  @relation("Referrals", fields: [referredById], references: [id])
  referrals             User[]                 @relation("Referrals")
  groupMemberships      GroupMember[]
  contributions         Contribution[]
  payoutsReceived       Payout[]
  agreementSignatures   AgreementSignature[]
  loansAsBorrower       Loan[]                 @relation("BorrowerLoans")
  loansAsGuarantor      LoanGuarantor[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  disputesRaised        Dispute[]              @relation("DisputeRaiser")
  disputesAgainst       Dispute[]              @relation("DisputeTarget")
  assetOwnerships       AssetOwnership[]
  propertyStakes        PropertyStake[]
  investmentAllocations InvestmentAllocation[]
  assetQueueEntries     AssetQueueEntry[]
  sentInvitations       MemberInvitation[]   @relation("SentInvitations")
  savingsPoolMemberships SavingsPoolMember[] @relation("UserSavingsPoolMemberships")
  savingsContributions  SavingsContribution[] @relation("UserSavingsContributions")
  savingsLoans          SavingsLoan[]        @relation("UserSavingsLoans")
  savingsPayouts        SavingsPoolPayout[]  @relation("UserSavingsPayouts")
  paymentMethods        PaymentMethodRecord[]
  reputationHistory     ReputationEvent[]
  kycDocuments          KycDocument[]
  adminGroups           Group[]                @relation("GroupAdmin")

  @@index([email])
  @@index([phone])
  @@index([kycStatus])
  @@index([status])
  @@index([reputationScore])
}

model KycDocument {
  id           String    @id @default(uuid())
  userId       String
  documentType String    // national_id, passport, drivers_licence, proof_of_address
  documentUrl  String    // Encrypted URL
  extractedData Json?    // OCR-extracted fields
  verifiedAt   DateTime?
  verifiedBy   String?
  rejectedAt   DateTime?
  rejectionReason String?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PaymentMethodRecord {
  id            String        @id @default(uuid())
  userId        String
  method        PaymentMethod
  accountRef    String        // Encrypted account reference
  accountName   String?
  isDefault     Boolean       @default(false)
  isVerified    Boolean       @default(false)
  currency      CurrencyCode  @default(USD)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ReputationEvent {
  id          String   @id @default(uuid())
  userId      String
  event       String
  scoreDelta  Decimal  @db.Decimal(8, 2)
  scoreAfter  Decimal  @db.Decimal(8, 2)
  entityType  String?  // contribution, payout, loan, cycle
  entityId    String?
  notes       String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// GROUPS & CYCLES
// ============================================================

model Group {
  id                   String         @id @default(uuid())
  name                 String
  description          String?
  adminUserId          String
  status               GroupStatus    @default(DRAFT)
  currency             CurrencyCode   @default(USD)
  contributionAmount   Decimal        @db.Decimal(18, 4)
  contributionDay      Int            // Day of month (1-28)
  contributionFrequency String        @default("monthly") // monthly, weekly, biweekly
  maxMembers           Int            @default(10)
  minMembers           Int            @default(4)
  penaltyRate          Decimal        @default(0.20) @db.Decimal(5, 4) // 20%
  insurancePoolPct     Decimal        @default(0.015) @db.Decimal(5, 4) // 1.5%
  platformFeePct       Decimal        @default(0.02) @db.Decimal(5, 4) // 2%
  payoutStrategy       PayoutStrategy @default(SENIORITY)
  escrowBalance        Decimal        @default(0) @db.Decimal(18, 4)
  insurancePoolBalance Decimal        @default(0) @db.Decimal(18, 4)
  escrowAccountRef     String?        // External escrow account reference
  logoUrl              String?
  coverImageUrl        String?
  isPublic             Boolean        @default(false)
  requiresVote         Boolean        @default(true) // New member requires vote
  country              String?
  region               String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  deletedAt            DateTime?

  // Relations
  admin           User              @relation("GroupAdmin", fields: [adminUserId], references: [id])
  members         GroupMember[]
  cycles          Cycle[]
  assets          Asset[]
  loans           Loan[]
  propertyGroups  PropertyGroup[]
  portfolio       InvestmentPortfolio?
  agreements      Agreement[]
  disputes        Dispute[]
  ledgerAccounts  LedgerAccount[]
  announcements   Announcement[]
  auditLogs       AuditLog[]
  savingsPools    SavingsPool[]          @relation("GroupSavingsPools")
  invitations     MemberInvitation[]     @relation("GroupInvitations")

  @@index([adminUserId])
  @@index([status])
}

model GroupMember {
  id             String       @id @default(uuid())
  groupId        String
  userId         String
  role           UserRole     @default(MEMBER)
  status         MemberStatus @default(ACTIVE)
  payoutPosition Int?         // Assigned position in payout queue
  votesToApprove Int          @default(0)
  votesRequired  Int          @default(3)
  joinedAt       DateTime     @default(now())
  exitedAt       DateTime?
  exitReason     String?
  invitedById    String?
  approvedById   String?
  approvedAt     DateTime?
  cyclesCompleted Int         @default(0)
  totalContributed Decimal    @default(0) @db.Decimal(18, 4)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@index([status])
}

model Cycle {
  id             String      @id @default(uuid())
  groupId        String
  cycleNumber    Int
  status         CycleStatus @default(PENDING)
  startDate      DateTime
  endDate        DateTime
  totalMembers   Int
  poolAmount     Decimal     @db.Decimal(18, 4) // contribution × members
  escrowBalance  Decimal     @default(0) @db.Decimal(18, 4)
  lockedAt       DateTime?   // When schedule was locked
  completedAt    DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  group           Group            @relation(fields: [groupId], references: [id])
  payoutSchedule  PayoutSchedule[]
  contributions   Contribution[]
  payouts         Payout[]

  @@unique([groupId, cycleNumber])
  @@index([groupId])
  @@index([status])
}

model PayoutSchedule {
  id              String      @id @default(uuid())
  cycleId         String
  recipientId     String
  monthNumber     Int
  scheduledDate   DateTime
  payoutAmount    Decimal     @db.Decimal(18, 4)
  status          PayoutStatus @default(SCHEDULED)
  lockedAt        DateTime    @default(now()) // Immutable after this
  createdAt       DateTime    @default(now())

  // NO updatedAt — this record is write-once / immutable
  cycle   Cycle  @relation(fields: [cycleId], references: [id])
  payout  Payout?

  @@unique([cycleId, monthNumber])
  @@unique([cycleId, recipientId])
  @@index([cycleId])
  @@index([recipientId])
}

// ============================================================
// CONTRIBUTIONS
// ============================================================

model Contribution {
  id              String             @id @default(uuid())
  cycleId         String
  userId          String
  monthNumber     Int
  amountDue       Decimal            @db.Decimal(18, 4)
  amountPaid      Decimal            @default(0) @db.Decimal(18, 4)
  currency        CurrencyCode       @default(USD)
  dueDate         DateTime
  paidAt          DateTime?
  status          ContributionStatus @default(PENDING)
  paymentMethod   PaymentMethod?
  paymentRef      String?
  retryCount      Int                @default(0)
  lastRetryAt     DateTime?
  failureReason   String?
  isPrePaid       Boolean            @default(false)
  preEscrowRef    String?            // Link to payout that triggered pre-escrow
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  cycle        Cycle         @relation(fields: [cycleId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@unique([cycleId, userId, monthNumber])
  @@index([cycleId])
  @@index([userId])
  @@index([status])
  @@index([dueDate])
}

// ============================================================
// PAYOUTS
// ============================================================

model Payout {
  id                  String       @id @default(uuid())
  cycleId             String
  recipientId         String
  scheduleId          String       @unique
  amount              Decimal      @db.Decimal(18, 4)
  currency            CurrencyCode @default(USD)
  status              PayoutStatus @default(PENDING_GATES)
  scheduledDate       DateTime
  processedAt         DateTime?
  completedAt         DateTime?
  paymentMethod       PaymentMethod?
  paymentRef          String?
  releaseAuthCode     String?      // Cryptographic release token
  preEscrowCollected  Decimal      @default(0) @db.Decimal(18, 4)
  preEscrowMonths     Int          @default(0)
  gate1Passed         Boolean      @default(false) // All contributions collected
  gate2Passed         Boolean      @default(false) // Recipient in good standing
  gate3Passed         Boolean      @default(false) // Agreement signed
  gate4Passed         Boolean      @default(false) // Escrow balance sufficient
  authorisedById      String?
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  cycle        Cycle          @relation(fields: [cycleId], references: [id])
  recipient    User           @relation(fields: [recipientId], references: [id])
  schedule     PayoutSchedule @relation(fields: [scheduleId], references: [id])
  transactions Transaction[]

  @@index([cycleId])
  @@index([recipientId])
  @@index([status])
}

// ============================================================
// TRANSACTIONS (Immutable Ledger)
// ============================================================

model Transaction {
  id               String            @id @default(uuid())
  type             TransactionType
  status           TransactionStatus @default(PENDING)
  amount           Decimal           @db.Decimal(18, 4)
  currency         CurrencyCode      @default(USD)
  exchangeRate     Decimal?          @db.Decimal(18, 6) // If currency conversion
  baseAmount       Decimal?          @db.Decimal(18, 4) // Amount in base currency
  description      String?
  reference        String            @unique @default(uuid())
  externalRef      String?           // Payment gateway reference
  paymentMethod    PaymentMethod?
  contributionId   String?
  payoutId         String?
  loanId           String?
  assetId          String?
  propertyGroupId  String?
  investmentId     String?
  groupId          String?
  userId           String?
  failureReason    String?
  reversedAt       DateTime?
  reversalRef      String?
  metadata         Json?
  createdAt        DateTime          @default(now())
  // NO updatedAt — transactions are append-only. Corrections via reversal.

  contribution    Contribution? @relation(fields: [contributionId], references: [id])
  payout          Payout?       @relation(fields: [payoutId], references: [id])
  loan            Loan?         @relation(fields: [loanId], references: [id])
  ledgerEntries   LedgerEntry[]

  @@index([type])
  @@index([status])
  @@index([userId])
  @@index([groupId])
  @@index([createdAt])
  @@index([reference])
}

// ============================================================
// ASSETS
// ============================================================

model Asset {
  id              String            @id @default(uuid())
  groupId         String
  name            String
  description     String?
  type            AssetType
  campaignType    AssetCampaignType @default(SHARED_OWNERSHIP)
  status          AssetStatus       @default(FUNDING)
  targetAmount    Decimal           @db.Decimal(18, 4)
  raisedAmount    Decimal           @default(0) @db.Decimal(18, 4)
  currency        CurrencyCode      @default(USD)
  fundingDeadline DateTime?
  acquiredAt      DateTime?
  acquisitionCost Decimal?          @db.Decimal(18, 4)
  currentValue    Decimal?          @db.Decimal(18, 4)
  location        String?
  serialNumber    String?
  vin             String?
  make            String?
  model           String?
  year            Int?
  condition       String?
  photoUrls       Json?
  documents       Json?
  incomeGenerated Decimal           @default(0) @db.Decimal(18, 4)
  disposedAt      DateTime?
  disposalPrice   Decimal?          @db.Decimal(18, 4)
  notes           String?
  unitsTotal      Int               @default(1)
  unitCost        Decimal?          @db.Decimal(18, 4)
  contributionPerMember Decimal?    @db.Decimal(18, 4)
  positionStrategy String           @default("SENIORITY")
  allowOutsiders  Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  group               Group                     @relation(fields: [groupId], references: [id])
  ownerships          AssetOwnership[]
  incomeDistributions AssetIncomeDistribution[]
  costingSheet        AssetCostingSheet?
  backers             AssetBacker[]
  incomes             AssetIncome[]            @relation("AssetIncomes")
  insurances          AssetInsurance[]         @relation("AssetInsurances")
  maintenances        AssetMaintenance[]       @relation("AssetMaintenances")
  depreciations       AssetDepreciation[]      @relation("AssetDepreciations")
  queue               AssetQueueEntry[]

  @@index([groupId])
  @@index([type])
  @@index([status])
  @@index([campaignType])
}

model AssetOwnership {
  id              String   @id @default(uuid())
  assetId         String
  userId          String
  ownershipPct    Decimal  @db.Decimal(10, 4) // e.g. 10.0000 = 10%
  amountContributed Decimal @db.Decimal(18, 4)
  currency        CurrencyCode @default(USD)
  acquiredAt      DateTime @default(now())
  transferredAt   DateTime?
  transferredToId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([assetId, userId])
  @@index([assetId])
  @@index([userId])
}

model AssetIncomeDistribution {
  id          String   @id @default(uuid())
  assetId     String
  totalIncome Decimal  @db.Decimal(18, 4)
  currency    CurrencyCode @default(USD)
  period      String   // e.g. "2025-07"
  description String?
  distributedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  asset   Asset                         @relation(fields: [assetId], references: [id])
  shares  AssetIncomeDistributionShare[]

  @@index([assetId])
}

model AssetIncomeDistributionShare {
  id             String  @id @default(uuid())
  distributionId String
  userId         String
  ownershipPct   Decimal @db.Decimal(10, 4)
  amount         Decimal @db.Decimal(18, 4)
  createdAt      DateTime @default(now())

  distribution AssetIncomeDistribution @relation(fields: [distributionId], references: [id])

  @@index([distributionId])
  @@index([userId])
}

// ============================================================
// PROPERTY INVESTMENT
// ============================================================

model PropertyGroup {
  id                String       @id @default(uuid())
  groupId           String
  name              String
  description       String?
  propertyAddress   String?
  propertyType      String?      // residential, commercial, agricultural
  status            String       @default("FUNDING") // FUNDING, ACQUIRED, RENTING, SOLD
  targetCapital     Decimal      @db.Decimal(18, 4)
  raisedCapital     Decimal      @default(0) @db.Decimal(18, 4)
  currency          CurrencyCode @default(USD)
  currentValue      Decimal?     @db.Decimal(18, 4)
  lastValuationDate DateTime?
  monthlyRental     Decimal?     @db.Decimal(18, 4)
  managementFeePct  Decimal      @default(0.10) @db.Decimal(5, 4) // 10%
  maintenanceReservePct Decimal  @default(0.05) @db.Decimal(5, 4) // 5%
  purchaseDate      DateTime?
  purchasePrice     Decimal?     @db.Decimal(18, 4)
  bondAmount        Decimal?     @db.Decimal(18, 4)
  bondProvider      String?
  titleDeedUrl      String?
  photoUrls         Json?
  documents         Json?
  soldAt            DateTime?
  salePrice         Decimal?     @db.Decimal(18, 4)
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  group              Group                 @relation(fields: [groupId], references: [id])
  stakes             PropertyStake[]
  rentalDistributions RentalDistribution[]
  valuations         PropertyValuation[]

  @@index([groupId])
}

model PropertyStake {
  id              String       @id @default(uuid())
  propertyGroupId String
  userId          String
  ownershipPct    Decimal      @db.Decimal(10, 4)
  totalContributed Decimal     @db.Decimal(18, 4)
  currency        CurrencyCode @default(USD)
  lockedAt        DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  propertyGroup PropertyGroup @relation(fields: [propertyGroupId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@unique([propertyGroupId, userId])
  @@index([propertyGroupId])
  @@index([userId])
}

model PropertyValuation {
  id              String   @id @default(uuid())
  propertyGroupId String
  valuationDate   DateTime
  marketValue     Decimal  @db.Decimal(18, 4)
  currency        CurrencyCode @default(USD)
  valuedBy        String?
  method          String?  // bank_valuation, estate_agent, municipal
  documentUrl     String?
  notes           String?
  createdAt       DateTime @default(now())

  propertyGroup PropertyGroup @relation(fields: [propertyGroupId], references: [id])

  @@index([propertyGroupId])
}

model RentalDistribution {
  id              String       @id @default(uuid())
  propertyGroupId String
  period          String       // "2025-07"
  grossRental     Decimal      @db.Decimal(18, 4)
  managementFee   Decimal      @db.Decimal(18, 4)
  maintenanceReserve Decimal   @db.Decimal(18, 4)
  platformFee     Decimal      @db.Decimal(18, 4)
  netDistributed  Decimal      @db.Decimal(18, 4)
  currency        CurrencyCode @default(USD)
  distributedAt   DateTime     @default(now())
  createdAt       DateTime     @default(now())

  propertyGroup PropertyGroup @relation(fields: [propertyGroupId], references: [id])
  shares        RentalDistributionShare[]

  @@index([propertyGroupId])
}

model RentalDistributionShare {
  id             String  @id @default(uuid())
  distributionId String
  userId         String
  ownershipPct   Decimal @db.Decimal(10, 4)
  amount         Decimal @db.Decimal(18, 4)
  createdAt      DateTime @default(now())

  distribution RentalDistribution @relation(fields: [distributionId], references: [id])

  @@index([distributionId])
  @@index([userId])
}

// ============================================================
// INVESTMENT PORTFOLIO
// ============================================================

model InvestmentPortfolio {
  id            String       @id @default(uuid())
  groupId       String       @unique
  name          String
  currency      CurrencyCode @default(USD)
  totalInvested Decimal      @default(0) @db.Decimal(18, 4)
  currentValue  Decimal      @default(0) @db.Decimal(18, 4)
  totalReturns  Decimal      @default(0) @db.Decimal(18, 4)
  benchmark     String?      // e.g. "JSE All Share", "CPI"
  managerId     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  group       Group                  @relation(fields: [groupId], references: [id])
  investments Investment[]
  allocations InvestmentAllocation[]

  @@index([groupId])
}

model Investment {
  id           String         @id @default(uuid())
  portfolioId  String
  name         String
  type         InvestmentType
  provider     String?        // Fund house, broker, company name
  identifier   String?        // Fund code, ticker, registration number
  currency     CurrencyCode   @default(USD)
  amountInvested Decimal      @db.Decimal(18, 4)
  currentValue Decimal?       @db.Decimal(18, 4)
  units        Decimal?       @db.Decimal(18, 6)  // Units held (unit trusts/equities)
  unitPrice    Decimal?       @db.Decimal(18, 6)  // Last known unit price
  lastPriceDate DateTime?
  purchaseDate DateTime
  maturityDate DateTime?
  annualReturn Decimal?       @db.Decimal(8, 4)   // Calculated annual return %
  status       String         @default("ACTIVE")  // ACTIVE, MATURED, LIQUIDATED
  documents    Json?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  portfolio   InvestmentPortfolio    @relation(fields: [portfolioId], references: [id])
  returns     InvestmentReturn[]

  @@index([portfolioId])
  @@index([type])
}

model InvestmentReturn {
  id            String       @id @default(uuid())
  investmentId  String
  period        String       // "2025-Q2"
  type          String       // dividend, interest, capital_gain
  amount        Decimal      @db.Decimal(18, 4)
  currency      CurrencyCode @default(USD)
  receivedAt    DateTime
  notes         String?
  createdAt     DateTime     @default(now())

  investment Investment @relation(fields: [investmentId], references: [id])

  @@index([investmentId])
}

model InvestmentAllocation {
  id          String   @id @default(uuid())
  portfolioId String
  userId      String
  allocationPct Decimal @db.Decimal(10, 4)
  amountContributed Decimal @db.Decimal(18, 4)
  currency    CurrencyCode @default(USD)
  lockedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolio InvestmentPortfolio @relation(fields: [portfolioId], references: [id])
  user      User                @relation(fields: [userId], references: [id])

  @@unique([portfolioId, userId])
  @@index([portfolioId])
  @@index([userId])
}


// ============================================================
// SAVINGS POOL MODULE
// ============================================================

enum SavingsPoolStatus {
  SETUP      // Being configured, not yet started
  ACTIVE     // Contributions running
  MATURED    // Period ended, awaiting distribution
  CLOSED     // Fully distributed
  CANCELLED
}

enum SavingsPoolFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
}

enum SavingsContributionStatus {
  PENDING
  PAID
  LATE
  WAIVED
  PARTIAL
}

enum SavingsPayoutStatus {
  PENDING
  PAID
  WITHHELD
}

model SavingsPool {
  id                  String              @id @default(uuid())
  groupId             String
  name                String
  description         String?
  periodMonths        Int                 // e.g. 12, 24, 36
  contributionAmount  Decimal             @db.Decimal(18,4)
  contributionFrequency SavingsPoolFrequency @default(MONTHLY)
  startDate           DateTime
  maturityDate        DateTime
  status              SavingsPoolStatus   @default(SETUP)
  currency            CurrencyCode        @default(USD)
  // Loan settings
  interestRatePa      Decimal             @default(0.24) @db.Decimal(6,4)
  maxLoanPct          Decimal             @default(0.50) @db.Decimal(5,4) // 50% of pool
  allowLoans          Boolean             @default(true)
  // Running totals
  totalContributed    Decimal             @default(0) @db.Decimal(18,4)
  totalInterestEarned Decimal             @default(0) @db.Decimal(18,4)
  totalPoolValue      Decimal             @default(0) @db.Decimal(18,4)
  // Distribution
  distributedAt       DateTime?
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  group         Group                  @relation("GroupSavingsPools", fields: [groupId], references: [id])
  members       SavingsPoolMember[]
  contributions SavingsContribution[]
  loans         SavingsLoan[]
  payouts       SavingsPoolPayout[]

  @@index([groupId])
  @@index([status])
}

model SavingsPoolMember {
  id               String   @id @default(uuid())
  poolId           String
  userId           String
  totalContributed Decimal  @default(0) @db.Decimal(18,4)
  sharePercentage  Decimal  @default(0) @db.Decimal(10,4)
  loanBalance      Decimal  @default(0) @db.Decimal(18,4)
  joinedAt         DateTime @default(now())
  exitedAt         DateTime?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  pool SavingsPool @relation(fields: [poolId], references: [id])
  user User        @relation("UserSavingsPoolMemberships", fields: [userId], references: [id])

  @@unique([poolId, userId])
  @@index([poolId])
  @@index([userId])
}

model SavingsContribution {
  id            String                    @id @default(uuid())
  poolId        String
  userId        String
  periodNumber  Int
  dueDate       DateTime
  amountDue     Decimal                   @db.Decimal(18,4)
  amountPaid    Decimal                   @default(0) @db.Decimal(18,4)
  currency      CurrencyCode              @default(USD)
  status        SavingsContributionStatus @default(PENDING)
  paidAt        DateTime?
  paymentMethod String?
  paymentRef    String?
  notes         String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  pool SavingsPool @relation(fields: [poolId], references: [id])
  user User        @relation("UserSavingsContributions", fields: [userId], references: [id])

  @@unique([poolId, userId, periodNumber])
  @@index([poolId])
  @@index([userId])
  @@index([dueDate])
  @@index([status])
}

model SavingsLoan {
  id                 String      @id @default(uuid())
  poolId             String
  borrowerId         String
  amount             Decimal     @db.Decimal(18,4)
  currency           CurrencyCode @default(USD)
  interestRatePa     Decimal     @db.Decimal(6,4)
  termMonths         Int
  purpose            String
  status             LoanStatus  @default(PENDING_APPROVAL)
  outstandingBalance Decimal     @default(0) @db.Decimal(18,4)
  totalInterestDue   Decimal     @default(0) @db.Decimal(18,4)
  totalInterestPaid  Decimal     @default(0) @db.Decimal(18,4)
  approvedAt         DateTime?
  approvedById       String?
  rejectedAt         DateTime?
  rejectionReason    String?
  disbursedAt        DateTime?
  settledAt          DateTime?
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  pool       SavingsPool          @relation(fields: [poolId], references: [id])
  borrower   User                 @relation("UserSavingsLoans", fields: [borrowerId], references: [id])
  repayments SavingsLoanRepayment[]

  @@index([poolId])
  @@index([borrowerId])
  @@index([status])
}

model SavingsLoanRepayment {
  id            String   @id @default(uuid())
  loanId        String
  installmentNo Int
  dueDate       DateTime
  principalDue  Decimal  @db.Decimal(18,4)
  interestDue   Decimal  @db.Decimal(18,4)
  totalDue      Decimal  @db.Decimal(18,4)
  amountPaid    Decimal  @default(0) @db.Decimal(18,4)
  status        SavingsContributionStatus @default(PENDING)
  paidAt        DateTime?
  paymentRef    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  loan SavingsLoan @relation(fields: [loanId], references: [id])

  @@unique([loanId, installmentNo])
  @@index([loanId])
  @@index([dueDate])
}

model SavingsPoolPayout {
  id            String             @id @default(uuid())
  poolId        String
  userId        String
  grossShare    Decimal            @db.Decimal(18,4)
  loanDeduction Decimal            @default(0) @db.Decimal(18,4)
  netPayout     Decimal            @db.Decimal(18,4)
  sharePercent  Decimal            @db.Decimal(10,4)
  currency      CurrencyCode       @default(USD)
  status        SavingsPayoutStatus @default(PENDING)
  paidAt        DateTime?
  paymentRef    String?
  notes         String?
  createdAt     DateTime           @default(now())

  pool SavingsPool @relation(fields: [poolId], references: [id])
  user User        @relation("UserSavingsPayouts", fields: [userId], references: [id])

  @@unique([poolId, userId])
  @@index([poolId])
  @@index([userId])
}

// ============================================================
// LOANS & MEMBER ASSISTANCE
// ============================================================

model Loan {
  id                String       @id @default(uuid())
  groupId           String
  borrowerId        String
  type              LoanType     @default(STANDARD)
  status            LoanStatus   @default(DRAFT)
  amount            Decimal      @db.Decimal(18, 4)
  currency          CurrencyCode @default(USD)
  interestRatePa    Decimal      @default(0) @db.Decimal(6, 4) // Annual rate e.g. 0.12 = 12%
  termMonths        Int
  purpose           String
  disbursedAt       DateTime?
  disbursementRef   String?
  settlementDate    DateTime?
  settledAt         DateTime?
  outstandingBalance Decimal     @default(0) @db.Decimal(18, 4)
  totalInterestDue  Decimal      @default(0) @db.Decimal(18, 4)
  totalInterestPaid Decimal      @default(0) @db.Decimal(18, 4)
  // Approval workflow
  treasurerReviewAt  DateTime?
  treasurerReviewBy  String?
  treasurerNotes     String?
  adminApprovedAt    DateTime?
  adminApprovedBy    String?
  adminNotes         String?
  rejectedAt         DateTime?
  rejectedBy         String?
  rejectionReason    String?
  supportingDocs     Json?
  isEmergency        Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  group       Group           @relation(fields: [groupId], references: [id])
  borrower    User            @relation("BorrowerLoans", fields: [borrowerId], references: [id])
  guarantors  LoanGuarantor[]
  repayments  LoanRepayment[]
  transactions Transaction[]

  @@index([groupId])
  @@index([borrowerId])
  @@index([status])
}

model LoanGuarantor {
  id               String    @id @default(uuid())
  loanId           String
  // Linked user (optional — guarantor may not be a platform member)
  userId           String?
  // External guarantor details
  fullName         String
  email            String
  phone            String
  // Approval token (emailed to guarantor)
  token            String    @unique @default(uuid())
  tokenExpiresAt   DateTime
  // Response
  status           String    @default("PENDING")  // PENDING, APPROVED, DECLINED
  acceptedAt       DateTime?
  rejectedAt       DateTime?
  rejectedReason   String?
  ipAddress        String?
  // Notification
  emailSentAt      DateTime?
  reminderSentAt   DateTime?
  // Liability
  liabilityTriggeredAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  loan Loan  @relation(fields: [loanId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  @@index([loanId])
  @@index([token])
  @@index([email])
}

model LoanRepayment {
  id              String            @id @default(uuid())
  loanId          String
  installmentNo   Int
  dueDate         DateTime
  principalDue    Decimal           @db.Decimal(18, 4)
  interestDue     Decimal           @db.Decimal(18, 4)
  totalDue        Decimal           @db.Decimal(18, 4)
  paidAt          DateTime?
  amountPaid      Decimal           @default(0) @db.Decimal(18, 4)
  status          ContributionStatus @default(PENDING)
  paymentRef      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  loan Loan @relation(fields: [loanId], references: [id])

  @@unique([loanId, installmentNo])
  @@index([loanId])
  @@index([dueDate])
  @@index([status])
}

// ============================================================
// FINANCIAL MANAGEMENT (General Ledger)
// ============================================================

model LedgerAccount {
  id            String   @id @default(uuid())
  groupId       String
  code          String   // e.g. "1000", "2000"
  name          String
  type          String   // ASSET, LIABILITY, EQUITY, INCOME, EXPENSE
  parentId      String?
  isActive      Boolean  @default(true)
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  group    Group          @relation(fields: [groupId], references: [id])
  parent   LedgerAccount? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children LedgerAccount[] @relation("AccountHierarchy")
  entries  LedgerEntry[]

  @@unique([groupId, code])
  @@index([groupId])
}

model LedgerEntry {
  id            String       @id @default(uuid())
  accountId     String
  transactionId String
  entryType     String       // DEBIT, CREDIT
  amount        Decimal      @db.Decimal(18, 4)
  currency      CurrencyCode @default(USD)
  description   String?
  period        String       // "2025-07" for reporting
  createdAt     DateTime     @default(now())
  // NO updatedAt — ledger entries are immutable. Corrections via reversal.

  account     LedgerAccount @relation(fields: [accountId], references: [id])
  transaction Transaction   @relation(fields: [transactionId], references: [id])

  @@index([accountId])
  @@index([transactionId])
  @@index([period])
}

model ExchangeRate {
  id           String       @id @default(uuid())
  fromCurrency CurrencyCode
  toCurrency   CurrencyCode
  rate         Decimal      @db.Decimal(18, 6)
  source       String?      // "open_exchange_rates", "manual"
  rateDate     DateTime
  createdAt    DateTime     @default(now())

  @@unique([fromCurrency, toCurrency, rateDate])
  @@index([fromCurrency, toCurrency])
  @@index([rateDate])
}

// ============================================================
// LEGAL AGREEMENTS
// ============================================================

model Agreement {
  id            String    @id @default(uuid())
  groupId       String
  version       String
  title         String
  contentHash   String    // SHA-256 of document content — tamper detection
  documentUrl   String    // Stored agreement document
  effectiveFrom DateTime
  status        String    @default("DRAFT") // DRAFT, ACTIVE, SUPERSEDED
  createdAt     DateTime  @default(now())

  group      Group                @relation(fields: [groupId], references: [id])
  signatures AgreementSignature[]

  @@index([groupId])
}

model AgreementSignature {
  id              String   @id @default(uuid())
  agreementId     String
  userId          String
  ipAddress       String
  deviceFingerprint String?
  signedAt        DateTime @default(now())
  signatureHash   String   // Cryptographic hash of signature

  agreement Agreement @relation(fields: [agreementId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([agreementId, userId])
  @@index([agreementId])
  @@index([userId])
}

// ============================================================
// COMMUNICATIONS
// ============================================================

model Notification {
  id          String              @id @default(uuid())
  userId      String
  channel     NotificationChannel
  status      NotificationStatus  @default(PENDING)
  subject     String?
  body        String
  templateId  String?
  metadata    Json?               // Channel-specific data
  externalId  String?             // Provider message ID
  sentAt      DateTime?
  deliveredAt DateTime?
  failedAt    DateTime?
  failReason  String?
  retryCount  Int                 @default(0)
  createdAt   DateTime            @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
}

model Announcement {
  id          String   @id @default(uuid())
  groupId     String
  authorId    String
  title       String
  body        String
  attachments Json?    // Array of file URLs
  isPinned    Boolean  @default(false)
  publishedAt DateTime @default(now())
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id])

  @@index([groupId])
  @@index([publishedAt])
}

// ============================================================
// DISPUTES
// ============================================================

model Dispute {
  id            String        @id @default(uuid())
  groupId       String
  raisedById    String
  againstUserId String?
  type          DisputeType
  status        DisputeStatus @default(OPEN)
  title         String
  description   String
  resolution    String?
  resolvedById  String?
  resolvedAt    DateTime?
  escalatedAt   DateTime?
  escalatedTo   String?
  closedAt      DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  group    Group           @relation(fields: [groupId], references: [id])
  raisedBy User            @relation("DisputeRaiser", fields: [raisedById], references: [id])
  against  User?           @relation("DisputeTarget", fields: [againstUserId], references: [id])
  evidence DisputeEvidence[]

  @@index([groupId])
  @@index([raisedById])
  @@index([status])
}

model DisputeEvidence {
  id          String   @id @default(uuid())
  disputeId   String
  submittedBy String
  evidenceType String  // screenshot, bank_statement, message, other
  fileUrl     String?
  description String?
  createdAt   DateTime @default(now())

  dispute Dispute @relation(fields: [disputeId], references: [id])

  @@index([disputeId])
}

// ============================================================
// AUDIT LOG (Immutable)
// ============================================================

model AuditLog {
  id          String      @id @default(uuid())
  userId      String?
  groupId     String?
  action      AuditAction
  entityType  String      // Table name
  entityId    String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  sessionId   String?
  description String?
  createdAt   DateTime    @default(now())
  // NO updatedAt — audit log is immutable

  user  User?  @relation(fields: [userId], references: [id])
  group Group? @relation(fields: [groupId], references: [id])

  @@index([userId])
  @@index([groupId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}


// ============================================================
// ASSET ROUND-ROBIN QUEUE
// ============================================================

model AssetQueueEntry {
  id              String           @id @default(uuid())
  assetId         String
  userId          String
  position        Int              // Queue position (1 = first to receive)
  status          AssetQueueStatus @default(WAITING)
  targetAmount    Decimal          @db.Decimal(18, 4)  // Cost for THIS member's unit
  raisedAmount    Decimal          @default(0) @db.Decimal(18, 4)
  fundingStarted  DateTime?
  orderedAt       DateTime?
  deliveredAt     DateTime?
  deliveryNotes   String?
  deliveryPhotoUrls Json?
  skippedAt       DateTime?
  skipReason      String?
  serialNumber    String?          // Unique serial for this member's unit
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  asset Asset @relation(fields: [assetId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([assetId, userId])
  @@unique([assetId, position])
  @@index([assetId])
  @@index([userId])
  @@index([status])
}


// ============================================================
// OUTSIDE CONTRIBUTORS (BACKERS)
// ============================================================

model AssetBacker {
  id               String          @id @default(uuid())
  assetId          String
  // Personal details — backers may not be platform users
  fullName         String
  email            String
  phone            String
  nationalId       String?         // Stored hashed
  country          String?
  city             String?
  occupation       String?
  // KYC
  kycStatus        BackerKycStatus @default(NOT_SUBMITTED)
  kycDocumentUrl   String?
  kycVerifiedAt    DateTime?
  kycVerifiedBy    String?
  kycRejectedAt    DateTime?
  kycRejectionNote String?
  // Approval
  status           BackerStatus    @default(PENDING_KYC)
  approvedById     String?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?
  // Contribution tracking
  totalContributed Decimal         @default(0) @db.Decimal(18,4)
  ownershipPct     Decimal         @default(0) @db.Decimal(10,4)
  currency         CurrencyCode    @default(USD)
  // Linked platform user (optional — if backer creates an account)
  linkedUserId     String?
  // Referral
  referredById     String?
  referralCode     String          @unique @default(uuid())
  // Terms
  agreedToTermsAt  DateTime?
  agreedToTermsIp  String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  asset            Asset           @relation(fields: [assetId], references: [id])
  contributions    BackerContribution[]

  @@unique([assetId, email])
  @@index([assetId])
}

model BackerContribution {
  id            String       @id @default(uuid())
  backerId      String
  assetId       String
  amount        Decimal      @db.Decimal(18,4)
  currency      CurrencyCode @default(USD)
  paymentMethod String       @default("BANK_TRANSFER")
  paymentRef    String?
  notes         String?
  recordedById  String?
  createdAt     DateTime     @default(now())

  backer AssetBacker @relation(fields: [backerId], references: [id])

  @@index([backerId])
  @@index([assetId])
  @@index([createdAt])
}


// ============================================================
// INCOME DISTRIBUTION
// ============================================================

model AssetIncome {
  id             String   @id @default(uuid())
  assetId        String
  groupId        String
  type           String   // RENTAL, HIRE, DIVIDEND, SALE_PROCEEDS, OTHER
  amount         Decimal  @db.Decimal(18,4)
  currency       CurrencyCode @default(USD)
  description    String
  incomeDate     DateTime
  collectedById  String?
  reference      String?
  expenses       Decimal  @default(0) @db.Decimal(18,4)
  netAmount      Decimal  @db.Decimal(18,4)
  status         String   @default("PENDING")  // PENDING, DISTRIBUTED, CANCELLED
  distributedAt  DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  asset         Asset                    @relation("AssetIncomes", fields: [assetId], references: [id])
  distributions AssetIncomeShare[]

  @@index([assetId])
  @@index([groupId])
  @@index([incomeDate])
}

model AssetIncomeShare {
  id          String   @id @default(uuid())
  incomeId    String
  assetId     String
  userId      String?   // null = backer
  backerId    String?
  ownershipPct Decimal @db.Decimal(10,4)
  shareAmount  Decimal @db.Decimal(18,4)
  currency     CurrencyCode @default(USD)
  status       String  @default("PENDING")  // PENDING, PAID, WITHHELD
  paidAt       DateTime?
  paymentRef   String?
  createdAt    DateTime @default(now())

  income AssetIncome @relation(fields: [incomeId], references: [id])

  @@index([incomeId])
  @@index([userId])
  @@index([backerId])
}

// ============================================================
// INSURANCE TRACKING
// ============================================================

model AssetInsurance {
  id              String   @id @default(uuid())
  assetId         String
  insurer         String
  policyNumber    String
  policyType      String   // COMPREHENSIVE, THIRD_PARTY, FIRE_THEFT, ALL_RISK, OTHER
  coverAmount     Decimal  @db.Decimal(18,4)
  currency        CurrencyCode @default(USD)
  premiumAmount   Decimal  @db.Decimal(18,4)
  premiumFrequency String  @default("ANNUAL") // MONTHLY, QUARTERLY, ANNUAL
  startDate       DateTime
  expiryDate      DateTime
  nextRenewalDate DateTime?
  status          String   @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED, LAPSED
  documentUrl     String?
  contactName     String?
  contactPhone    String?
  contactEmail    String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  asset  Asset            @relation("AssetInsurances", fields: [assetId], references: [id])
  claims AssetInsuranceClaim[]

  @@index([assetId])
  @@index([expiryDate])
}

model AssetInsuranceClaim {
  id           String   @id @default(uuid())
  insuranceId  String
  assetId      String
  claimDate    DateTime
  description  String
  claimAmount  Decimal  @db.Decimal(18,4)
  currency     CurrencyCode @default(USD)
  status       String   @default("SUBMITTED") // SUBMITTED, UNDER_REVIEW, APPROVED, REJECTED, PAID
  settledAmount Decimal? @db.Decimal(18,4)
  settledAt    DateTime?
  referenceNo  String?
  documentUrl  String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  insurance AssetInsurance @relation(fields: [insuranceId], references: [id])

  @@index([insuranceId])
  @@index([assetId])
}

// ============================================================
// MAINTENANCE & DEPRECIATION
// ============================================================

model AssetMaintenance {
  id              String   @id @default(uuid())
  assetId         String
  type            String   // SERVICE, REPAIR, INSPECTION, OVERHAUL, OTHER
  description     String
  performedBy     String?
  vendor          String?
  cost            Decimal  @db.Decimal(18,4)
  currency        CurrencyCode @default(USD)
  scheduledDate   DateTime?
  completedDate   DateTime?
  nextDueDate     DateTime?
  nextDueMileage  Int?
  mileageAtService Int?
  status          String   @default("SCHEDULED") // SCHEDULED, COMPLETED, OVERDUE, CANCELLED
  invoiceUrl      String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  asset Asset @relation("AssetMaintenances", fields: [assetId], references: [id])

  @@index([assetId])
  @@index([scheduledDate])
  @@index([status])
}

model AssetDepreciation {
  id             String   @id @default(uuid())
  assetId        String
  method         String   @default("STRAIGHT_LINE") // STRAIGHT_LINE, DECLINING_BALANCE
  usefulLifeYears Int     @default(5)
  residualValue  Decimal  @db.Decimal(18,4) @default(0)
  acquisitionCost Decimal @db.Decimal(18,4)
  currentValue   Decimal  @db.Decimal(18,4)
  depreciationRate Decimal @db.Decimal(8,4)
  lastCalculatedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  asset Asset @relation("AssetDepreciations", fields: [assetId], references: [id])

  @@unique([assetId])
}

// ============================================================
// SUPPLIER MANAGEMENT
// ============================================================

model Supplier {
  id              String   @id @default(uuid())
  name            String
  tradingName     String?
  country         String
  city            String?
  address         String?
  phone           String?
  email           String?
  website         String?
  contactPerson   String?
  contactPhone    String?
  contactEmail    String?
  category        String   // MACHINERY, VEHICLES, ELECTRONICS, PROPERTY, SERVICES, OTHER
  currencies      Json?    // Accepted currencies
  paymentTerms    String?
  leadTimeDays    Int?
  rating          Int?     // 1-5 stars
  isVerified      Boolean  @default(false)
  verifiedAt      DateTime?
  taxNumber       String?
  bankDetails     Json?
  notes           String?
  tags            Json?
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE, BLACKLISTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  quotes SupplierQuote[]

  @@index([category])
  @@index([country])
  @@index([status])
}

model SupplierQuote {
  id           String   @id @default(uuid())
  supplierId   String
  assetId      String?  // Linked to an asset campaign (optional)
  title        String
  description  String?
  currency     CurrencyCode @default(USD)
  unitPrice    Decimal  @db.Decimal(18,4)
  quantity     Int      @default(1)
  totalPrice   Decimal  @db.Decimal(18,4)
  incoterms    String?  // FOB, CIF, EXW, DDP etc
  validUntil   DateTime?
  leadTimeDays Int?
  paymentTerms String?
  includesFreight Boolean @default(false)
  includesInstall Boolean @default(false)
  documentUrl  String?
  status       String   @default("RECEIVED") // RECEIVED, SHORTLISTED, ACCEPTED, REJECTED, EXPIRED
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([assetId])
  @@index([status])
}


// ============================================================
// MEMBER INVITATIONS
// ============================================================

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
  RESENT
}

enum InvitationChannel {
  EMAIL
  SMS
  BOTH
}

model MemberInvitation {
  id              String            @id @default(uuid())
  groupId         String
  invitedById     String
  email           String?
  phone           String?
  fullName        String?
  role            String            @default("MEMBER")
  token           String            @unique @default(uuid())
  status          InvitationStatus  @default(PENDING)
  channel         InvitationChannel @default(BOTH)
  expiresAt       DateTime
  acceptedAt      DateTime?
  cancelledAt     DateTime?
  acceptedUserId  String?           // User created on acceptance
  personalMessage String?
  emailSentAt     DateTime?
  smsSentAt       DateTime?
  reminderSentAt  DateTime?
  resendCount     Int               @default(0)
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  group     Group  @relation("GroupInvitations", fields: [groupId], references: [id])
  invitedBy User   @relation("SentInvitations",  fields: [invitedById], references: [id])

  @@index([groupId])
  @@index([token])
  @@index([status])
  @@index([email])
}

// ============================================================
// ASSET COSTING SHEET
// ============================================================

model AssetCostingSheet {
  id              String   @id @default(uuid())
  assetId         String   @unique
  title           String   @default("Asset Cost Breakdown")
  currency        CurrencyCode @default(USD)
  units           Int      @default(1)       // How many units being purchased
  membersSharing  Int      @default(1)       // Members splitting the cost
  contingencyPct  Decimal  @default(5) @db.Decimal(5,2)  // % contingency
  notes           String?
  status          String   @default("DRAFT") // DRAFT, APPROVED, FINAL
  approvedById    String?
  approvedAt      DateTime?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  asset    Asset              @relation(fields: [assetId], references: [id])
  items    AssetCostingItem[]

  @@index([assetId])
}

model AssetCostingItem {
  id          String   @id @default(uuid())
  sheetId     String
  category    String   // PURCHASE, FREIGHT, CUSTOMS, SERVICES, OTHER
  description String
  amount      Decimal  @db.Decimal(18,4)
  currency    CurrencyCode @default(USD)
  isPerUnit   Boolean  @default(true)  // true = multiplied by units
  isOptional  Boolean  @default(false)
  included    Boolean  @default(true)
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sheet AssetCostingSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@index([sheetId])
}
